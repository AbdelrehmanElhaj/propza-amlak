<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- إغلاق المكالمات العالقة في حالة 'ringing' (webhook مفقود/بيانات فاسدة) -->
        <record id="cron_call_center_close_stale_ringing" model="ir.cron">
            <field name="name">مركز الاتصال: إغلاق المكالمات العالقة (رنين)</field>
            <field name="model_id" ref="model_sa_call_center_call"/>
            <field name="state">code</field>
            <field name="code">model._cron_close_stale_ringing_calls()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">20</field>
        </record>

    </data>
</odoo>
