<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client action: embeds /callcenter/dashboard inside Odoo webclient (iframe) -->
    <record id="action_call_center_dashboard" model="ir.actions.client">
        <field name="name">لوحة تحكم مركز الاتصال</field>
        <field name="tag">call_center_dashboard_action</field>
    </record>

    <menuitem id="menu_call_center_root"
              name="مركز الاتصال"
              sequence="35"/>

    <menuitem id="menu_call_center_calls"
              name="المكالمات"
              parent="menu_call_center_root"
              action="action_call_center_call"
              sequence="10"/>

    <menuitem id="menu_call_center_tickets"
              name="التذاكر"
              parent="menu_call_center_root"
              action="action_call_center_ticket"
              sequence="20"/>

    <menuitem id="menu_call_center_dashboard"
              name="لوحة التحكم"
              parent="menu_call_center_root"
              action="action_call_center_dashboard"
              sequence="25"/>

    <menuitem id="menu_call_center_config"
              name="الإعدادات"
              parent="menu_call_center_root"
              sequence="100"/>

    <menuitem id="menu_call_center_queues"
              name="قوائم الانتظار"
              parent="menu_call_center_config"
              action="action_call_center_queue"
              sequence="10"/>

</odoo>
