<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_call_center" model="ir.ui.view">
        <field name="name">res.partner.form.call.center</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_calls" type="object"
                        class="oe_stat_button" icon="fa-phone">
                    <field name="sa_call_count" widget="statinfo" string="مكالمات"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='phone'][@widget='phone'][not(ancestor::field[@name='child_ids'])]"
                   position="attributes">
                <attribute name="widget">sa_call_center_phone</attribute>
            </xpath>
            <xpath expr="//field[@name='mobile'][@widget='phone'][not(ancestor::field[@name='child_ids'])]"
                   position="attributes">
                <attribute name="widget">sa_call_center_phone</attribute>
            </xpath>
        </field>
    </record>

</odoo>
