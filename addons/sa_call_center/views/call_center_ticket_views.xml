<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_call_center_ticket_tree" model="ir.ui.view">
        <field name="name">sa.call.center.ticket.tree</field>
        <field name="model">sa.call.center.ticket</field>
        <field name="arch" type="xml">
            <tree decoration-info="state=='new'" decoration-muted="state=='done'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="category"/>
                <field name="user_id"/>
                <field name="state" widget="badge"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <record id="view_call_center_ticket_form" model="ir.ui.view">
        <field name="name">sa.call.center.ticket.form</field>
        <field name="model">sa.call.center.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_convert_to_lead" type="object"
                            string="تحويل إلى طلب CRM" class="btn-secondary"
                            invisible="lead_id"/>
                    <button name="action_convert_to_maintenance" type="object"
                            string="تحويل إلى طلب صيانة" class="btn-secondary"
                            invisible="maintenance_request_id"/>
                    <button name="action_close" type="object"
                            string="إغلاق" class="btn-primary"
                            invisible="state == 'done'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="call_id"/>
                            <field name="property_id"/>
                        </group>
                        <group>
                            <field name="category"/>
                            <field name="user_id"/>
                            <field name="lead_id" readonly="1"/>
                            <field name="maintenance_request_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_call_center_ticket" model="ir.actions.act_window">
        <field name="name">التذاكر</field>
        <field name="res_model">sa.call.center.ticket</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">إنشاء تذكرة جديدة</p>
            <p>للحالات التي لا تناسب طلب CRM أو طلب صيانة قائم مباشرة.</p>
        </field>
    </record>

</odoo>
