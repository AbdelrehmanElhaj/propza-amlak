<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_sa_sadad_invoice" model="ir.sequence">
            <field name="name">فاتورة SADAD</field>
            <field name="code">sa.sadad.invoice</field>
            <field name="prefix">SADAD/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Daily cron to mark expired invoices -->
        <record id="cron_sadad_expire" model="ir.cron">
            <field name="name">SADAD: تحديث الفواتير منتهية الصلاحية</field>
            <field name="model_id" ref="model_sa_sadad_invoice"/>
            <field name="state">code</field>
            <field name="code">model.cron_expire_old_invoices()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
