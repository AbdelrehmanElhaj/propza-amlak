<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- إضافة زر "إصدار SADAD" + حقول على form الدفعة -->
    <record id="view_sa_rent_payment_form_sadad" model="ir.ui.view">
        <field name="name">sa.rent.payment.form.sadad</field>
        <field name="model">sa.rent.payment</field>
        <field name="inherit_id" ref="sa_rental_cycle.view_sa_rent_payment_form"/>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="has_active_sadad" invisible="1"/>
                <field name="sadad_invoice_ids" invisible="1"/>
                <button name="action_generate_sadad" string="إصدار SADAD"
                        type="object" class="btn-secondary"
                        invisible="state in ('paid','cancelled') or has_active_sadad"
                        icon="fa-qrcode"/>
                <button name="action_view_sadad_invoices" string="عرض فواتير SADAD"
                        type="object" class="btn-secondary"
                        invisible="not sadad_invoice_ids"/>
            </xpath>
        </field>
    </record>

</odoo>
