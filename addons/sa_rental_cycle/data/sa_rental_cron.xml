<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_rent_payment" model="ir.sequence">
            <field name="name">دفعة إيجار</field>
            <field name="code">sa.rent.payment</field>
            <field name="prefix">PAY/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <!-- Maintenance sequence moved to module 'sa_maintenance'
             (sa_maintenance.seq_sa_maintenance_request) -->

        <record id="cron_check_expiry" model="ir.cron">
            <field name="name">فحص انتهاء عقود الإيجار</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">env['property.tenancy'].cron_check_expiry_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="cron_auto_renew" model="ir.cron">
            <field name="name">تجديد عقود الإيجار التلقائي</field>
            <field name="model_id" ref="sa_property_base.model_property_tenancy"/>
            <field name="state">code</field>
            <field name="code">model.cron_auto_renew_tenancies()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
