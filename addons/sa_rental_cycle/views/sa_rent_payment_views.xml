<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sa_rent_payment_tree" model="ir.ui.view">
        <field name="name">sa.rent.payment.tree</field>
        <field name="model">sa.rent.payment</field>
        <field name="arch" type="xml">
            <tree string="جدول الدفعات"
                  decoration-danger="state == 'overdue'"
                  decoration-success="state == 'paid'"
                  decoration-warning="state == 'partial'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="period_label" string="الفترة"/>
                <field name="due_date"/>
                <field name="amount" string="المستحق (ريال)"/>
                <field name="amount_paid" string="المدفوع (ريال)"/>
                <field name="balance" string="الرصيد (ريال)"/>
                <field name="payment_type"/>
                <field name="payment_method"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'overdue'"
                       decoration-success="state == 'paid'"
                       decoration-warning="state == 'partial'"/>
                <field name="days_overdue" string="أيام التأخير"/>
                <button name="action_open_payment_wizard" type="object"
                        string="تسجيل دفع" class="btn-primary"
                        invisible="state in ('paid','cancelled')"/>
            </tree>
        </field>
    </record>

    <record id="view_sa_rent_payment_form" model="ir.ui.view">
        <field name="name">sa.rent.payment.form</field>
        <field name="model">sa.rent.payment</field>
        <field name="arch" type="xml">
            <form string="دفعة إيجار">
                <header>
                    <button name="action_open_payment_wizard"
                            string="تسجيل دفع" type="object"
                            class="btn-primary"
                            invisible="state in ('paid','cancelled')"/>
                    <button name="action_mark_paid" string="تأكيد الدفع"
                            type="object"
                            invisible="state in ('paid','cancelled')"/>
                    <button name="action_create_invoice"
                            string="إنشاء فاتورة" type="object"
                            class="btn-secondary"
                            invisible="move_id != False or state == 'cancelled'"/>
                    <button name="action_view_invoice"
                            string="عرض الفاتورة" type="object"
                            invisible="move_id == False"/>
                    <button name="action_cancel" string="إلغاء"
                            type="object" class="btn-danger"
                            invisible="state in ('paid','cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,overdue,paid"/>
                </header>
                <sheet>
                    <group string="بيانات الدفعة">
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="tenancy_id"/>
                            <field name="payment_type"/>
                            <field name="due_date"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="period_label" readonly="1"/>
                            <field name="days_overdue" readonly="1"/>
                            <field name="penalty_amount" readonly="1"/>
                            <field name="balance" readonly="1"/>
                        </group>
                    </group>
                    <group string="بيانات الدفع"
                           invisible="state not in ('paid','partial')">
                        <group>
                            <field name="payment_date"/>
                            <field name="payment_method"/>
                            <field name="amount_paid"/>
                        </group>
                        <group>
                            <field name="sadad_number"
                                   invisible="payment_method != 'sadad'"/>
                            <field name="cheque_number"
                                   invisible="payment_method != 'cheque'"/>
                            <field name="bank_ref"
                                   invisible="payment_method != 'bank_transfer'"/>
                        </group>
                    </group>
                    <group string="الفوترة" invisible="not move_id">
                        <field name="move_id" readonly="1"/>
                        <field name="move_state" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── Graph view (revenue analytics) ────────────────────── -->
    <record id="view_sa_rent_payment_graph" model="ir.ui.view">
        <field name="name">sa.rent.payment.graph</field>
        <field name="model">sa.rent.payment</field>
        <field name="arch" type="xml">
            <graph string="تحليل الدفعات" type="bar" sample="1">
                <field name="due_date" interval="month" type="row"/>
                <field name="amount" type="measure"/>
                <field name="amount_paid" type="measure"/>
                <field name="balance" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ─── Pivot view (revenue analytics) ────────────────────── -->
    <record id="view_sa_rent_payment_pivot" model="ir.ui.view">
        <field name="name">sa.rent.payment.pivot</field>
        <field name="model">sa.rent.payment</field>
        <field name="arch" type="xml">
            <pivot string="تحليل الدفعات" sample="1">
                <field name="property_id" type="row"/>
                <field name="due_date" interval="month" type="col"/>
                <field name="amount" type="measure"/>
                <field name="amount_paid" type="measure"/>
                <field name="balance" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_sa_rent_payments" model="ir.actions.act_window">
        <field name="name">جدول الدفعات</field>
        <field name="res_model">sa.rent.payment</field>
        <field name="view_mode">tree,graph,pivot,form</field>
        <field name="context">{'search_default_overdue': 1}</field>
    </record>

    <!-- ─── Revenue analytics action (separate menu entry) ───── -->
    <record id="action_sa_rent_payment_analytics" model="ir.actions.act_window">
        <field name="name">تحليل الإيرادات</field>
        <field name="res_model">sa.rent.payment</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="context">{'search_default_paid': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">تحليل الإيرادات</p>
            <p>عرض تفاعلي للدفعات حسب الشهر، العقار، والحالة.</p>
        </field>
    </record>

    <menuitem id="menu_revenue_analytics"
              name="تحليل الإيرادات"
              parent="sa_property_base.menu_pms_root"
              action="action_sa_rent_payment_analytics"
              sequence="40"/>

    <record id="action_sa_rent_payments_overdue" model="ir.actions.act_window">
        <field name="name">دفعات متأخرة</field>
        <field name="res_model">sa.rent.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state','=','overdue')]</field>
    </record>

</odoo>
