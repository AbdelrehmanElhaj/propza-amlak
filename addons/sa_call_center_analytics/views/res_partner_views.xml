<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_call_center_analytics" model="ir.ui.view">
        <field name="name">res.partner.form.call.center.analytics</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_calls" type="object"
                        class="oe_stat_button" icon="fa-clock-o">
                    <field name="sa_call_talk_duration_total" widget="statinfo"
                           string="إجمالي وقت التحدث (ثانية)"/>
                </button>
                <button name="action_view_calls" type="object"
                        class="oe_stat_button" icon="fa-repeat"
                        invisible="sa_call_repeat_count == 0">
                    <field name="sa_call_repeat_count" widget="statinfo" string="مكالمات مكررة"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
