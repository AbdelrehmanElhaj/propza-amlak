<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
        ═══════════════════════════════════════════════════════════════
        Ejar queue_job maintenance crons
        ═══════════════════════════════════════════════════════════════

        Worker channel configuration (add to odoo.cfg):
        ─────────────────────────────────────────────────
        [queue_job]
        channels = root:4,root.ejar:8,root.ejar.contracts:2,root.ejar.polling:10,root.ejar.documents:3

        Channels:
          root.ejar.contracts  — heavy submission pipelines (2 workers)
          root.ejar.polling    — lightweight status polls   (10 workers)
          root.ejar.documents  — PDF uploads                (3 workers)
        ═══════════════════════════════════════════════════════════════
        -->

        <!-- Dead-letter cleanup: find contracts stuck in 'submitting'
             whose queue.job has permanently failed, reset to 'ready'. -->
        <record id="cron_ejar_cleanup_dead_letter" model="ir.cron">
            <field name="name">إيجار: تنظيف مهام الإرسال الفاشلة</field>
            <field name="model_id" ref="model_ejar_contract"/>
            <field name="state">code</field>
            <field name="code">model._cron_cleanup_dead_letter_jobs()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">20</field>
        </record>

        <!-- Sync-log purge: delete records older than 90 days. -->
        <record id="cron_ejar_purge_sync_logs" model="ir.cron">
            <field name="name">إيجار: حذف سجلات المزامنة القديمة (90 يوم)</field>
            <field name="model_id" ref="model_ejar_contract"/>
            <field name="state">code</field>
            <field name="code">model._cron_purge_old_sync_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">30</field>
        </record>

        <!-- Completed-job purge: keep queue.job table lean. -->
        <record id="cron_ejar_purge_completed_jobs" model="ir.cron">
            <field name="name">إيجار: حذف مهام قائمة الانتظار المكتملة (30 يوم)</field>
            <field name="model_id" ref="model_ejar_contract"/>
            <field name="state">code</field>
            <field name="code">model._cron_purge_completed_jobs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">30</field>
        </record>

    </data>
</odoo>
