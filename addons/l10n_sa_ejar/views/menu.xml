<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Top-level Ejar menu ───────────────────────────────────── -->
    <menuitem id="menu_ejar_root"
              name="إيجار"
              sequence="30"
              web_icon="l10n_sa_ejar,static/description/icon.png"/>

    <!-- ── Contracts ────────────────────────────────────────────── -->
    <menuitem id="menu_ejar_contracts"
              name="عقود إيجار"
              parent="menu_ejar_root"
              action="action_ejar_contract"
              sequence="10"/>

    <!-- ── Brokerage profiles ────────────────────────────────────── -->
    <menuitem id="menu_ejar_brokerage_profiles"
              name="ملفات مكاتب الوساطة"
              parent="menu_ejar_root"
              action="action_ejar_brokerage_profile"
              sequence="20"/>

    <!-- ── Sync logs ─────────────────────────────────────────────── -->
    <menuitem id="menu_ejar_sync_logs"
              name="سجلات المزامنة"
              parent="menu_ejar_root"
              action="action_ejar_sync_log"
              sequence="30"
              groups="base.group_system"/>

    <!-- ── Configuration ─────────────────────────────────────────── -->
    <menuitem id="menu_ejar_config"
              name="الإعدادات"
              parent="menu_ejar_root"
              sequence="90"
              groups="base.group_system"/>

    <menuitem id="menu_sa_regions"
              name="المناطق الإدارية السعودية"
              parent="menu_ejar_config"
