<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         ejar.brokerage.profile — Form View
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_ejar_brokerage_profile_form" model="ir.ui.view">
        <field name="name">ejar.brokerage.profile.form</field>
        <field name="model">ejar.brokerage.profile</field>
        <field name="arch" type="xml">
            <form string="ملف مكتب الوساطة">
                <header>
                    <field name="is_verified" widget="boolean_toggle"
                           options="{'terminology': {'true': 'تم التحقق', 'false': 'لم يتم التحقق'}}"/>
                </header>
                <sheet>
                    <field name="license_expired" invisible="1"/>
                    <div class="alert alert-warning" role="alert"
                         invisible="not license_expired">
                        <i class="fa fa-exclamation-triangle"/> &#160;
                        <strong>تحذير:</strong> ترخيص ريرا منتهي الصلاحية.
                        لن يمكن إرسال عقود جديدة حتى يتم التجديد.
                    </div>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_contracts" type="object"
                                class="oe_stat_button" icon="fa-file-text-o">
                            <field name="contract_count" widget="statinfo" string="العقود"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="office_name_ar" string="اسم المكتب"/>
                        <h1><field name="office_name_ar" placeholder="اسم المكتب بالعربية"/></h1>
                        <h4><field name="office_name_en" placeholder="Office Name in English"/></h4>
                    </div>

                    <group>
                        <group string="بيانات التسجيل">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="cr_number"/>
                            <field name="unified_number"/>
                            <field name="license_number"/>
                            <field name="license_expiry"/>
                            <field name="vat_number"/>
                        </group>
                        <group string="الممثل القانوني">
                            <field name="representative_partner_id"/>
                            <field name="representative_id_number" readonly="1"/>
                            <field name="representative_mobile" readonly="1"/>
                        </group>
                    </group>

                    <group string="العنوان الوطني">
                        <group>
                            <field name="national_address_code"/>
                            <field name="building_number"/>
                            <field name="street_ar"/>
                            <field name="district_ar"/>
                        </group>
                        <group>
                            <field name="sa_region_id"/>
                            <field name="sa_city_id"
                                   domain="[('region_id', '=', sa_region_id)]"/>
                            <field name="postal_code"/>
                        </group>
                    </group>

                    <group string="إيجار — منصة" groups="base.group_system">
                        <field name="ejar_office_id" readonly="1"/>
                        <field name="ejar_registered" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         ejar.brokerage.profile — List View
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_ejar_brokerage_profile_list" model="ir.ui.view">
        <field name="name">ejar.brokerage.profile.list</field>
        <field name="model">ejar.brokerage.profile</field>
        <field name="arch" type="xml">
            <tree string="ملفات مكاتب الوساطة"
                  decoration-warning="license_expired"
                  decoration-muted="not active">
                <field name="office_name_ar"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="cr_number"/>
                <field name="license_number"/>
                <field name="license_expiry"/>
                <field name="is_verified" widget="boolean_toggle"/>
                <field name="contract_count"/>
                <field name="license_expired" column_invisible="1"/>
                <field name="active" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         ejar.brokerage.profile — Action
    ═══════════════════════════════════════════════════════════════ -->
    <record id="action_ejar_brokerage_profile" model="ir.actions.act_window">
        <field name="name">ملفات مكاتب الوساطة</field>
        <field name="res_model">ejar.brokerage.profile</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">أضف ملف مكتب الوساطة</p>
            <p>
                يجب إضافة ملف وساطة لكل شركة قبل إرسال أي عقد إلى إيجار.
                الهوية القانونية للمكتب هي التي تظهر في عقود إيجار.
            </p>
        </field>
    </record>

</odoo>
