<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sa_region_list" model="ir.ui.view">
        <field name="name">sa.region.list</field>
        <field name="model">sa.region</field>
        <field name="arch" type="xml">
            <tree string="المناطق الإدارية">
                <field name="code"/>
                <field name="name_ar"/>
                <field name="name"/>
                <field name="capital_ar"/>
                <field name="city_count"/>
            </tree>
        </field>
    </record>

    <record id="view_sa_region_form" model="ir.ui.view">
        <field name="name">sa.region.form</field>
        <field name="model">sa.region</field>
        <field name="arch" type="xml">
            <form string="منطقة إدارية">
                <sheet>
                    <group>
                        <group>
                            <field name="name_ar"/>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="capital_ar"/>
                            <field name="capital"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="المدن">
                            <field name="city_ids">
                                <tree editable="bottom">
                                    <field name="name_ar"/>
                                    <field name="name"/>
                                    <field name="rent_freeze"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sa_region" model="ir.actions.act_window">
        <field name="name">المناطق الإدارية</field>
        <field name="res_model">sa.region</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
