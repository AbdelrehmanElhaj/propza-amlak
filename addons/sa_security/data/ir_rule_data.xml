        <!-- ═══════════════════════════════════════════════════════
             AGENT RULES — يرى جميع طلبات الصيانة وأوامر العمل
             ═══════════════════════════════════════════════════════ -->

        <record id="rule_maintenance_request_agent" model="ir.rule">
            <field name="name">Agent: all maintenance requests</field>
            <field name="model_id" ref="sa_maintenance.model_sa_maintenance_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_pms_agent'))]"/>
