<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ═══════════════════════════════════════════════════════
             OWNER RULES — يرى عقاراته وعقوده ودفعاته فقط
             ═══════════════════════════════════════════════════════ -->

        <record id="rule_property_owner_own" model="ir.rule">
            <field name="name">Owner: own properties only</field>
            <field name="model_id" ref="sa_property_base.model_property_property"/>
            <field name="domain_force">[('owner_partner_id.user_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('group_pms_owner'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_tenancy_owner_own" model="ir.rule">
            <field name="name">Owner: own tenancies only</field>
            <field name="model_id" ref="sa_property_base.model_property_tenancy"/>
