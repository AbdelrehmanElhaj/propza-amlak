<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List -->
    <record id="view_sa_crm_stage_list" model="ir.ui.view">
        <field name="name">sa.crm.stage.list</field>
        <field name="model">sa.crm.stage</field>
        <field name="arch" type="xml">
            <tree string="مراحل CRM" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="probability"/>
                <field name="is_won"/>
                <field name="fold"/>
            </tree>
        </field>
    </record>

    <!-- Form -->
    <record id="view_sa_crm_stage_form" model="ir.ui.view">
        <field name="name">sa.crm.stage.form</field>
        <field name="model">sa.crm.stage</field>
        <field name="arch" type="xml">
            <form string="مرحلة CRM">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="probability"/>
                        </group>
                        <group>
                            <field name="is_won"/>
                            <field name="fold"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sa_crm_stage" model="ir.actions.act_window">
        <field name="name">المراحل</field>
        <field name="res_model">sa.crm.stage</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
