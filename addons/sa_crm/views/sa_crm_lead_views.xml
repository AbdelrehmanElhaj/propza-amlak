<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kanban -->
    <record id="view_sa_crm_lead_kanban" model="ir.ui.view">
        <field name="name">sa.crm.lead.kanban</field>
        <field name="model">sa.crm.lead</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column">
                <field name="partner_id"/>
                <field name="lead_type"/>
                <field name="budget_max"/>
                <field name="priority"/>
                <field name="user_id"/>
                <field name="kanban_state"/>
                <field name="stage_id"/>
                <field name="state"/>
                <field name="rooms_min"/>
                <field name="rooms_max"/>
                <field name="area_min_sqm"/>
                <field name="area_max_sqm"/>
                <field name="days_open"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="partner_id"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_top_right">
                                    <field name="priority" widget="priority"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="lead_type" widget="badge"
                                       decoration-info="lead_type == 'rent'"
                                       decoration-warning="lead_type == 'buy'"/>
                                <div t-if="record.budget_max.raw_value">
                                    <field name="budget_max" widget="monetary"/>
                                </div>
                                <div t-if="record.rooms_min.raw_value" class="text-muted small">
                                    <i class="fa fa-bed"/> <t t-esc="record.rooms_min.value"/>
                                    <t t-if="record.rooms_max.raw_value">–<t t-esc="record.rooms_max.value"/></t>
                                    غرف
                                </div>
                                <div t-if="record.area_min_sqm.raw_value" class="text-muted small">
                                    <i class="fa fa-arrows-alt"/> <t t-esc="record.area_min_sqm.value"/> م²
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="kanban_state" widget="kanban_state_selection"/>
                                    <t t-if="record.days_open.raw_value > 30">
                                        <span class="badge badge-warning ms-1">
                                            <i class="fa fa-clock-o"/> <t t-esc="record.days_open.value"/> يوم
                                        </span>
                                    </t>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List -->
    <record id="view_sa_crm_lead_list" model="ir.ui.view">
        <field name="name">sa.crm.lead.list</field>
        <field name="model">sa.crm.lead</field>
        <field name="arch" type="xml">
            <tree string="الطلبات"
                  decoration-success="state == 'won'"
                  decoration-muted="state == 'lost'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="lead_type"/>
                <field name="property_type"/>
                <field name="stage_id"/>
                <field name="user_id"/>
                <field name="budget_max"/>
                <field name="rooms_min"/>
                <field name="days_open" string="أيام"/>
                <field name="date_deadline"/>
                <field name="priority" widget="priority"/>
                <field name="state" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form -->
    <record id="view_sa_crm_lead_form" model="ir.ui.view">
        <field name="name">sa.crm.lead.form</field>
        <field name="model">sa.crm.lead</field>
        <field name="arch" type="xml">
            <form string="طلب CRM">
                <header>
                    <button name="action_mark_won" type="object"
                            string="فاز بالصفقة" class="oe_highlight"
                            invisible="state != 'open'"/>
                    <button name="action_mark_lost" type="object"
                            string="خسر الصفقة"
                            invisible="state != 'open'"/>
                    <button name="action_reopen" type="object"
                            string="إعادة فتح"
                            invisible="state == 'open'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="open,won,lost"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_showings" type="object"
                                class="oe_stat_button" icon="fa-map-marker">
                            <field name="showing_count" widget="statinfo"
                                   string="الجولات"/>
                        </button>
                        <button name="action_find_matching_properties" type="object"
                                class="oe_stat_button" icon="fa-home">
                            <field name="matching_count" widget="statinfo"
                                   string="عقارات مطابقة"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="العميل">
                            <field name="partner_id"/>
                            <field name="phone" readonly="1"/>
                            <field name="email" readonly="1"/>
                        </group>
                        <group string="التصنيف">
                            <field name="lead_type"/>
                            <field name="property_type"/>
                            <field name="source"/>
                            <field name="priority" widget="priority"/>
                        </group>
                    </group>
                    <group>
                        <group string="الميزانية">
                            <field name="budget_min" widget="monetary"/>
                            <field name="budget_max" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="expected_commission" widget="monetary"/>
                        </group>
                        <group string="التفاصيل">
                            <field name="preferred_region_id"/>
                            <field name="property_id"/>
                            <field name="user_id"/>
                            <field name="stage_id"/>
                            <field name="kanban_state"/>
                            <field name="date_deadline"/>
                            <field name="days_open" readonly="1"/>
                        </group>
                    </group>

                    <!-- Property Requirements -->
                    <group string="متطلبات العقار">
                        <group string="الأبعاد والمواصفات">
                            <field name="rooms_min"/>
                            <field name="rooms_max"/>
                            <field name="bathrooms_min"/>
                            <field name="area_min_sqm"/>
                            <field name="area_max_sqm"/>
                            <field name="furnished_pref"/>
                        </group>
                        <group string="المرافق المطلوبة">
                            <field name="parking_required" widget="boolean_toggle"/>
                            <field name="pool_required" widget="boolean_toggle"/>
                            <field name="garden_required" widget="boolean_toggle"/>
                            <field name="elevator_required" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group invisible="state != 'lost'">
                        <field name="lost_reason" string="سبب الخسارة"/>
                    </group>
                    <notebook>
                        <page string="الجولات الميدانية" name="showings">
                            <field name="showing_ids">
                                <tree editable="bottom">
                                    <field name="scheduled_date"/>
                                    <field name="property_id"/>
                                    <field name="user_id"/>
                                    <field name="outcome"/>
                                    <field name="interest_level"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                        <page string="ملاحظات" name="notes">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search -->
    <record id="view_sa_crm_lead_search" model="ir.ui.view">
        <field name="name">sa.crm.lead.search</field>
        <field name="model">sa.crm.lead</field>
        <field name="arch" type="xml">
            <search string="بحث في الطلبات">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <separator/>
                <filter name="open"      string="مفتوح"    domain="[('state','=','open')]"/>
                <filter name="won"       string="فاز"      domain="[('state','=','won')]"/>
                <filter name="lost"      string="خسر"      domain="[('active','=',False),('state','=','lost')]"/>
                <filter name="my_leads"  string="طلباتي"   domain="[('user_id','=',uid)]"/>
                <separator/>
                <filter name="rent"      string="إيجار"    domain="[('lead_type','=','rent')]"/>
                <filter name="buy"       string="شراء"     domain="[('lead_type','=','buy')]"/>
                <separator/>
                <filter name="high_priority" string="عاجل" domain="[('priority','=','2')]"/>
                <group expand="0" string="تجميع حسب">
                    <filter name="group_stage"        string="المرحلة"    context="{'group_by':'stage_id'}"/>
                    <filter name="group_user"         string="الموظف"     context="{'group_by':'user_id'}"/>
                    <filter name="group_lead_type"    string="نوع الطلب"  context="{'group_by':'lead_type'}"/>
                    <filter name="group_property_type" string="نوع العقار" context="{'group_by':'property_type'}"/>
                    <filter name="group_source"       string="المصدر"     context="{'group_by':'source'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sa_crm_lead" model="ir.actions.act_window">
        <field name="name">الطلبات</field>
        <field name="res_model">sa.crm.lead</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_sa_crm_lead_search"/>
        <field name="context">{'search_default_open': 1}</field>
    </record>

</odoo>
