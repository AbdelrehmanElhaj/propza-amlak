<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_sa_crm_lead" model="ir.sequence">
            <field name="name">طلب CRM</field>
            <field name="code">sa.crm.lead</field>
            <field name="prefix">CRM/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_sa_crm_reservation" model="ir.sequence">
            <field name="name">حجز وحدة</field>
            <field name="code">sa.crm.reservation</field>
            <field name="prefix">RES/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
