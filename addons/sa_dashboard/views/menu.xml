<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client action: embeds /pms/dashboard inside Odoo webclient (iframe) -->
    <record id="action_pms_dashboard_client" model="ir.actions.client">
        <field name="name">لوحة التحكم</field>
        <field name="tag">pms_dashboard_action</field>
    </record>

    <!-- Standalone top-level app — first item on the home screen -->
    <menuitem id="menu_pms_dashboard"
              name="لوحة التحكم"
              action="action_pms_dashboard_client"
              sequence="5"
              web_icon="sa_dashboard,static/description/icon.png"/>

</odoo>
