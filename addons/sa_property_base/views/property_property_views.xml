<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List -->
    <record id="view_property_property_list" model="ir.ui.view">
        <field name="name">property.property.list</field>
        <field name="model">property.property</field>
        <field name="arch" type="xml">
            <tree string="العقارات" decoration-success="state=='on_rent'" decoration-muted="state=='sold'">
                <field name="name"/>
                <field name="flat_name"/>
                <field name="property_type"/>
                <field name="owner_partner_id"/>
                <field name="rent_amount" sum="إجمالي الإيجار"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Form -->
    <record id="view_property_property_form" model="ir.ui.view">
        <field name="name">property.property.form</field>
        <field name="model">property.property</field>
        <field name="arch" type="xml">
            <form string="العقار">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,on_rent,sold"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tenancies" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="tenancy_count" widget="statinfo" string="عقود الإيجار"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="اسم العقار"/></h1>
                        <h3><field name="flat_name" placeholder="اسم الوحدة"/></h3>
                    </div>
                    <group>
                        <group>
                            <field name="property_type"/>
                            <field name="owner_partner_id"/>
                            <field name="tenant_partner_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="rent_amount" widget="monetary"/>
                            <field name="price_amount" widget="monetary"/>
                            <field name="deposit_amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="الوصف">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search -->
    <record id="view_property_property_search" model="ir.ui.view">
        <field name="name">property.property.search</field>
        <field name="model">property.property</field>
        <field name="arch" type="xml">
            <search string="بحث في العقارات">
                <field name="name"/>
                <field name="owner_partner_id"/>
                <field name="property_type"/>
                <separator/>
                <filter name="available"  string="متاح"   domain="[('state','=','draft')]"/>
                <filter name="on_rent"    string="مؤجر"   domain="[('state','=','on_rent')]"/>
                <filter name="sold"       string="مباع"   domain="[('state','=','sold')]"/>
                <separator/>
                <filter name="residential" string="سكني"  domain="[('property_type','=','residential')]"/>
                <filter name="commercial"  string="تجاري"  domain="[('property_type','=','commercial')]"/>
                <filter name="industrial"  string="صناعي" domain="[('property_type','=','industrial')]"/>
                <filter name="land"        string="أرض"   domain="[('property_type','=','land')]"/>
                <group expand="0" string="تجميع حسب">
                    <filter name="group_state" string="الحالة" context="{'group_by':'state'}"/>
                    <filter name="group_type"  string="النوع" context="{'group_by':'property_type'}"/>
                    <filter name="group_owner" string="المالك" context="{'group_by':'owner_partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_property_property" model="ir.actions.act_window">
        <field name="name">العقارات</field>
        <field name="res_model">property.property</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_property_property_search"/>
    </record>

</odoo>
