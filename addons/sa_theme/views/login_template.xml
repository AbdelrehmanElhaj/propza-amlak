<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Override login_layout: full landing-page split-screen
         ============================================================ -->
    <template id="sa_login_layout" inherit_id="web.login_layout" name="SA Theme - Login Layout">

        <!-- Swap body class to our own so we can reset Odoo's bg-100 -->
        <xpath expr="//t[@t-set='body_classname']" position="replace">
            <t t-set="body_classname" t-value="'sa-login-body'"/>
        </xpath>

        <!-- Replace the default container card with a full-page split design -->
        <xpath expr="//div[hasclass('container')]" position="replace">
            <div class="sa-login-page">

                <!-- ── Left / brand panel ──────────────────────── -->
                <div class="sa-brand-panel" aria-hidden="true">
                    <!-- geometric accent circles (pure CSS) -->
                    <div class="sa-geo sa-geo-1"/>
                    <div class="sa-geo sa-geo-2"/>
                    <div class="sa-geo sa-geo-3"/>

                    <div class="sa-brand-content" dir="rtl">
                        <div class="sa-brand-logo">
                            <img t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}"
                                 alt="شعار المنصة"/>
                        </div>

                        <h1 class="sa-brand-title">منصة أملاك</h1>
                        <p class="sa-brand-subtitle">نظام إدارة العقارات المتكامل للسوق السعودية</p>

                        <ul class="sa-features-list">
                            <li>
                                <span class="sa-feat-icon">🏢</span>
                                إدارة العقود والوحدات العقارية
                            </li>
                            <li>
                                <span class="sa-feat-icon">💳</span>
                                تتبع المدفوعات والمتأخرات
                            </li>
                            <li>
                                <span class="sa-feat-icon">📊</span>
                                لوحة تحكم تفاعلية بالوقت الفعلي
                            </li>
                            <li>
                                <span class="sa-feat-icon">🔗</span>
                                تكامل منصة إيجار الوطنية
                            </li>
                            <li>
                                <span class="sa-feat-icon">🔧</span>
                                نظام الصيانة والمعاينات الميدانية
                            </li>
                            <li>
                                <span class="sa-feat-icon">🌐</span>
                                بوابة المستأجر الإلكترونية
                            </li>
                        </ul>

                        <div class="sa-brand-footer">
                            © 2026 Propza · منصة إدارة العقارات السعودية
                        </div>
                    </div>
                </div>

                <!-- ── Right / login panel ─────────────────────── -->
                <div class="sa-login-panel">
                    <div class="sa-login-inner" dir="rtl">

                        <div class="sa-login-header">
                            <img t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}"
                                 alt="Logo" class="sa-login-logo-img"/>
                            <h2 class="sa-login-title">مرحباً بك</h2>
                            <p class="sa-login-subtitle">سجّل دخولك للمتابعة</p>
                        </div>

                        <!-- slot: the <form> from web.login is injected here -->
                        <t t-out="0"/>

                        <div class="sa-login-footer-note" t-if="not disable_footer">
                            <t t-if="not disable_database_manager">
                                <a href="/web/database/manager" class="sa-db-link">إدارة قواعد البيانات</a>
                            </t>
                        </div>

                    </div>
                </div>

            </div>
        </xpath>
    </template>


    <!-- ============================================================
         Override web.login form: Arabic labels + RTL-safe inputs
         ============================================================ -->
    <template id="sa_login_form" inherit_id="web.login" name="SA Theme - Login Form">

        <!-- Arabic label: Email -->
        <xpath expr="//label[@for='login']" position="replace">
            <label for="login" class="form-label">البريد الإلكتروني</label>
        </xpath>

        <!-- Keep email input LTR (it's a technical field) -->
        <xpath expr="//input[@id='login']" position="attributes">
            <attribute name="dir">ltr</attribute>
            <attribute name="placeholder">أدخل بريدك الإلكتروني</attribute>
        </xpath>

        <!-- Arabic label: Password -->
        <xpath expr="//label[@for='password']" position="replace">
            <label for="password" class="form-label">كلمة المرور</label>
        </xpath>

        <!-- Keep password input LTR -->
        <xpath expr="//input[@id='password']" position="attributes">
            <attribute name="dir">ltr</attribute>
            <attribute name="placeholder">••••••••</attribute>
        </xpath>

        <!-- Arabic submit button -->
        <xpath expr="//button[contains(@class,'btn-primary') and @type='submit']" position="replace">
            <button type="submit" class="btn btn-primary w-100">
                تسجيل الدخول
            </button>
        </xpath>

    </template>

</odoo>
