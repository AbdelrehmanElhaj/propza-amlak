<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Theme Configuration -->
        <record id="propza_theme_config" model="ir.config_parameter">
            <field name="key">theme.propza.primary_color</field>
            <field name="value">#0066CC</field>
        </record>
        
        <record id="propza_theme_secondary_config" model="ir.config_parameter">
            <field name="key">theme.propza.secondary_color</field>
            <field name="value">#00A86B</field>
        </record>
        
        <record id="propza_theme_accent_config" model="ir.config_parameter">
            <field name="key">theme.propza.accent_color</field>
            <field name="value">#FFB84D</field>
        </record>

        <!-- Theme Settings Menu - Removed for now -->
