<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List -->
    <record id="view_sa_project_list" model="ir.ui.view">
        <field name="name">sa.project.list</field>
        <field name="model">sa.project</field>
        <field name="arch" type="xml">
            <tree string="المشاريع العقارية">
                <field name="name"/>
                <field name="developer_partner_id"/>
                <field name="sa_city_id"/>
                <field name="state"/>
                <field name="unit_count"/>
            </tree>
        </field>
    </record>

    <!-- Kanban (top-level menu view) -->
    <record id="view_sa_project_kanban" model="ir.ui.view">
        <field name="name">sa.project.kanban</field>
        <field name="model">sa.project</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="developer_partner_id"/>
                <field name="sa_city_id"/>
                <field name="state"/>
                <field name="unit_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><field name="developer_partner_id"/></div>
                                <div><field name="sa_city_id"/></div>
                                <div><field name="unit_count"/> وحدة</div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'planning'"
                                           decoration-warning="state == 'under_construction'"
                                           decoration-success="state in ('ready', 'completed')"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form -->
    <record id="view_sa_project_form" model="ir.ui.view">
        <field name="name">sa.project.form</field>
        <field name="model">sa.project</field>
        <field name="arch" type="xml">
            <form string="مشروع عقاري">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="planning,under_construction,ready,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_units" type="object" class="oe_stat_button" icon="fa-building">
                            <field name="unit_count" widget="statinfo" string="الوحدات"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="اسم المشروع"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="developer_partner_id"/>
                            <field name="sa_region_id"/>
                            <field name="sa_city_id"/>
                            <field name="sa_district"/>
                        </group>
                        <group>
                            <field name="sa_national_address"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="الوصف">
                            <field name="description"/>
                        </page>
                        <page string="الوحدات">
                            <field name="unit_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="flat_name"/>
                                    <field name="property_type"/>
                                    <field name="rent_amount"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="معرض الصور">
                            <field name="image_ids" context="{'default_project_id': id}">
                                <kanban default_group_by="media_type" class="o_kanban_small_column">
                                    <field name="name"/>
                                    <field name="media_type"/>
                                    <field name="image"/>
                                    <field name="image_filename"/>
                                    <field name="is_image"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_card oe_kanban_global_click">
                                                <div class="o_kanban_image">
                                                    <img t-if="record.is_image.raw_value"
                                                         t-att-src="kanban_image('sa.project.image', 'image', record.id.raw_value)"
                                                         class="o_kanban_image_fill_left"
                                                         style="width:100px;height:75px;object-fit:cover;"
                                                         alt="صورة"/>
                                                    <div t-if="!record.is_image.raw_value"
                                                         style="width:100px;height:75px;display:flex;align-items:center;justify-content:center;">
                                                        <i class="fa fa-file-o fa-2x" title="ملف"/>
                                                    </div>
                                                </div>
                                                <div class="o_kanban_record_body">
                                                    <strong><field name="name"/></strong>
                                                    <div><field name="image_filename"/></div>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="media_type"/>
                                        <field name="sequence"/>
                                        <field name="image" widget="image"/>
                                        <field name="image_filename"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search -->
    <record id="view_sa_project_search" model="ir.ui.view">
        <field name="name">sa.project.search</field>
        <field name="model">sa.project</field>
        <field name="arch" type="xml">
            <search string="بحث في المشاريع">
                <field name="name"/>
                <field name="developer_partner_id"/>
                <field name="sa_city_id"/>
                <filter name="planning" string="تخطيط" domain="[('state','=','planning')]"/>
                <filter name="under_construction" string="تحت الإنشاء" domain="[('state','=','under_construction')]"/>
                <filter name="ready" string="جاهز" domain="[('state','=','ready')]"/>
                <filter name="completed" string="مكتمل" domain="[('state','=','completed')]"/>
                <group expand="0" string="تجميع حسب">
                    <filter name="group_state" string="الحالة" context="{'group_by':'state'}"/>
                    <filter name="group_developer" string="المطوّر" context="{'group_by':'developer_partner_id'}"/>
                    <filter name="group_city" string="المدينة" context="{'group_by':'sa_city_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sa_project" model="ir.actions.act_window">
        <field name="name">المشاريع العقارية</field>
        <field name="res_model">sa.project</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_sa_project_search"/>
    </record>

</odoo>
