<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── List ──────────────────────────────────────────────── -->
    <record id="view_sales_target_tree" model="ir.ui.view">
        <field name="name">sa.sales.target.list</field>
        <field name="model">sa.sales.target</field>
        <field name="arch" type="xml">
            <tree string="أهداف المبيعات"
                  decoration-success="achievement_pct >= 100"
                  decoration-warning="achievement_pct &gt;= 70 and achievement_pct &lt; 100"
                  decoration-danger="achievement_pct &lt; 70">
                <field name="name"/>
                <field name="scope"/>
                <field name="period_type"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="target_amount" sum="إجمالي الأهداف"/>
                <field name="achieved_amount" sum="إجمالي المحقَّق"/>
                <field name="achievement_pct" widget="percentage"/>
            </tree>
        </field>
    </record>

    <!-- ─── Form ──────────────────────────────────────────────── -->
    <record id="view_sales_target_form" model="ir.ui.view">
        <field name="name">sa.sales.target.form</field>
        <field name="model">sa.sales.target</field>
        <field name="arch" type="xml">
            <form string="هدف مبيعات">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="النطاق">
                            <field name="scope" widget="radio"/>
                            <field name="user_id"
                                   required="scope == 'user'"
                                   invisible="scope != 'user'"/>
                            <field name="team_id"
                                   required="scope == 'team'"
                                   invisible="scope != 'team'"/>
                        </group>
                        <group string="الفترة">
                            <field name="period_type"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group>
                        <group string="الهدف والإنجاز">
                            <field name="target_amount"/>
                            <field name="achieved_amount" readonly="1"
                                   widget="progressbar"
                                   options="{'current_value': 'achieved_amount', 'max_value': 'target_amount'}"/>
                            <field name="achievement_pct" readonly="1" widget="percentage"/>
                        </group>
                    </group>
                    <field name="company_id" invisible="1"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── Search ────────────────────────────────────────────── -->
    <record id="view_sales_target_search" model="ir.ui.view">
        <field name="name">sa.sales.target.search</field>
        <field name="model">sa.sales.target</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="user_id"/>
                <field name="team_id"/>
                <separator/>
                <filter name="filt_user" string="فردي" domain="[('scope', '=', 'user')]"/>
                <filter name="filt_team" string="فريق" domain="[('scope', '=', 'team')]"/>
                <separator/>
                <filter name="filt_month" string="شهري" domain="[('period_type', '=', 'month')]"/>
                <filter name="filt_quarter" string="ربع سنوي" domain="[('period_type', '=', 'quarter')]"/>
                <filter name="filt_year" string="سنوي" domain="[('period_type', '=', 'year')]"/>
                <group expand="0" string="تجميع حسب">
                    <filter name="g_user" string="الموظف" context="{'group_by': 'user_id'}"/>
                    <filter name="g_team" string="الفريق" context="{'group_by': 'team_id'}"/>
                    <filter name="g_period_type" string="نوع الفترة" context="{'group_by': 'period_type'}"/>
                    <filter name="g_date_from" string="تاريخ البداية" context="{'group_by': 'date_from:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────── -->
    <record id="action_sales_target" model="ir.actions.act_window">
        <field name="name">أهداف المبيعات</field>
        <field name="res_model">sa.sales.target</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sales_target_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">إنشاء هدف مبيعات جديد</p>
            <p>حدّد هدف عمولات لموظف أو لفريق كامل عن فترة شهرية/ربع سنوية/سنوية، وتابع نسبة الإنجاز آلياً.</p>
        </field>
    </record>

</odoo>
