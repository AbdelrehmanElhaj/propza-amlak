<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_maintenance_request" model="ir.sequence">
        <field name="name">طلب صيانة</field>
        <field name="code">sa.maintenance.request</field>
        <field name="prefix">MNT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_maintenance_work_order" model="ir.sequence">
        <field name="name">أمر عمل صيانة</field>
        <field name="code">sa.maintenance.work_order</field>
        <field name="prefix">WO/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
